---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}
const { post } = Astro.props;
const { Content } = await post.render();
---
<Layout title={post.data.title}>
  <article>
    <!-- 戻る -->
    <a href="/" class="back-link">← HOMEへ戻る</a>
    <!-- タイトル -->
    <h1>{post.data.title}</h1>
    <!-- 日付 -->
    <p class="date">公開日: {post.data.date?.toString()}</p>
    <hr />
    <!-- 本文 -->
    <div class="content">
       <Content />
    </div>
    <!-- CTA -->
    <section class="cta">
      <h2>まずは1つだけ使ってみる</h2>
      <p>
        AIは読むより、実際に触ったほうが早く理解できます。
      </p>
      <div class="cta-buttons">
        <a href="/tools/chatgpt" class="cta-btn">ChatGPTを使ってみる</a>
        <a href="/tools/claude" class="cta-btn">Claudeも見てみる</a>
      </div>
    </section>
  </article>
  <style>
    article {
      margin-top: 20px;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      color: var(--subtext);
      padding: 6px 12px;
      border: 1px solid var(--border);
      border-radius: 999px;
      transition: all 0.2s;
    }
    .back-link:hover {
      color: var(--text);
      background: var(--surface-2);
      text-decoration: none;
    }

    h1 {
      margin-top: 20px;
      font-size: clamp(1.5rem, 4vw, 2rem);
      line-height: 1.4;
    }

    .date {
      font-size: 0.85rem;
      color: var(--subtext);
    }

    hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 30px 0;
    }

    /* ===== 本文スタイル（prose相当） ===== */
    .content {
      font-size: 1rem;
      line-height: 1.9;
      color: var(--subtext);
    }

    .content p {
      margin-bottom: 16px;
    }

    /* 太字 */
    .content strong {
      font-weight: 700;
      color: var(--text);
    }

    /* 斜体 */
    .content em {
      font-style: italic;
    }

    /* 見出し */
    .content h2 {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--text);
      margin-top: 40px;
      margin-bottom: 12px;
      padding-bottom: 8px;
      border-bottom: 2px solid var(--border);
    }

    .content h3 {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text);
      margin-top: 28px;
      margin-bottom: 8px;
    }

    /* リンク */
    .content a {
      color: var(--accent-1);
      text-decoration: underline;
      text-decoration-color: rgba(91,79,255,0.3);
      text-underline-offset: 3px;
      transition: color 0.2s;
    }

    .content a:hover {
      color: var(--accent-2);
    }

    /* リスト */
    .content ul {
      list-style: none;
      padding-left: 0;
      margin-bottom: 16px;
    }

    .content ul li {
      padding-left: 1.4em;
      position: relative;
      margin-bottom: 8px;
      color: var(--subtext);
    }

    .content ul li::before {
      content: '✦';
      position: absolute;
      left: 0;
      font-size: 0.6em;
      top: 0.35em;
      background: var(--gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .content ol {
      padding-left: 1.5em;
      margin-bottom: 16px;
    }

    .content ol li {
      margin-bottom: 8px;
      color: var(--subtext);
    }

    /* テーブル */
    .content table {
      width: 100%;
      border-collapse: collapse;
      margin: 20px 0;
      font-size: 0.9rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
    }

    .content th {
      background: var(--surface-2);
      color: var(--text);
      font-weight: 700;
      text-align: left;
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
    }

    .content td {
      padding: 10px 14px;
      color: var(--subtext);
      border-bottom: 1px solid var(--border);
    }

    .content tr:last-child td {
      border-bottom: none;
    }

    /* コード */
    .content code {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 2px 6px;
      font-size: 0.85em;
      font-family: 'Courier New', monospace;
      color: var(--accent-1);
    }

    /* 水平線 */
    .content hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 32px 0;
    }

    /* 画像 */
    .content img {
      max-width: 100%;
      border-radius: 8px;
      margin: 16px 0;
    }

    /* ===== CTA ===== */
    .cta {
      margin-top: 60px;
      padding-top: 20px;
      border-top: 1px solid var(--border);
    }

    .cta-buttons {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 12px;
    }

    @media (max-width: 640px) {
      .cta-buttons {
        flex-direction: column;
      }
    }
  </style>
</Layout>

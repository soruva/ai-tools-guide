---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const posts = await Astro.glob('../../content/blog/*.md');
  return posts.map(post => ({
    params: { slug: post.file.split('/').pop().split('.').shift() },
    props: { post },
  }));
}
const { Content, frontmatter } = Astro.props.post;
---

<Layout title={frontmatter.title}>
  <article style="background: #ffffff; padding: 40px; border-radius: 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); margin-top: 20px;">
    <a href="/" style="text-decoration: none; color: #0984e3; font-weight: 500; font-size: 0.9rem;">← HOMEへ戻る</a>
    <h1 style="margin-top: 20px; font-size: 2rem; border-left: none; padding-left: 0;">{frontmatter.title}</h1>
    <p style="color: #666; font-size: 0.9rem;">公開日: {frontmatter.date}</p>
    <hr style="border: 0; border-top: 1px solid #f0f0f0; margin: 30px 0;" />
    
    <div style="font-size: 1.1rem; line-height: 1.8;">
      <Content />
    </div>
  </article>
</Layout>

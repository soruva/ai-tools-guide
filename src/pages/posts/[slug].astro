---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, allPosts: posts },
  }));
}
const { post, allPosts } = Astro.props;
const { Content } = await post.render();

// おすすめ記事（現在の記事を除いた最新3件）
const recommended = allPosts
  .filter((p) => p.slug !== post.slug)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<Layout title={post.data.title}>

  <!-- 戻るボタン -->
  <a href="/" class="back-link">← HOMEへ戻る</a>

  <div class="page-layout">

    <!-- ===== メイン本文 ===== -->
    <article class="article">
      <h1>{post.data.title}</h1>
      <p class="date">公開日: {post.data.date?.toString()}</p>
      <hr />
      <div class="content">
        <Content />
      </div>
      <!-- 記事下CTA -->
      <section class="cta">
        <h2>まずは1つだけ使ってみる</h2>
        <p>AIは読むより、実際に触ったほうが早く理解できます。</p>
        <div class="cta-buttons">
          <a href="/tools/chatgpt" class="cta-btn">ChatGPTを使ってみる</a>
          <a href="/tools/claude" class="cta-btn cta-btn--secondary">Claudeも見てみる</a>
        </div>
      </section>
    </article>

    <!-- ===== サイドバー ===== -->
    <aside class="sidebar">

      <!-- 目次 -->
      <div class="sidebar-card" id="toc-card">
        <div class="sidebar-card__title">📋 目次</div>
        <nav id="toc" class="toc">
          <p class="toc-loading">読み込み中...</p>
        </nav>
      </div>

      <!-- おすすめ記事 -->
      <div class="sidebar-card">
        <div class="sidebar-card__title">✦ おすすめ記事</div>
        <ul class="rec-list">
          {recommended.map((p) => (
            <li class="rec-item">
              <a href={`/posts/${p.slug}`} class="rec-link">
                {p.data.title}
              </a>
              <span class="rec-date">{p.data.date}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- CTAバナー -->
      <div class="sidebar-card sidebar-cta">
        <div class="sidebar-cta__emoji">🤖</div>
        <div class="sidebar-cta__title">まずChatGPTを無料で試す</div>
        <p class="sidebar-cta__desc">登録5分、すぐ使える。初心者に一番おすすめのAIツール。</p>
        <a href="/tools/chatgpt" class="cta-btn" style="width:100%;text-align:center;display:block;">無料で始める</a>
      </div>

    </aside>
  </div>

  <style>
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--accent-1);
      padding: 8px 16px;
      border: 1.5px solid var(--accent-1);
      border-radius: 999px;
      margin-bottom: 24px;
      transition: all 0.2s;
      background: rgba(91,79,255,0.05);
    }
    .back-link:hover {
      background: var(--accent-1);
      color: #fff;
      text-decoration: none;
    }

    /* ===== 2カラムレイアウト ===== */
    .page-layout {
      display: grid;
      grid-template-columns: 1fr 260px;
      gap: 32px;
      align-items: start;
    }

    /* ===== 記事 ===== */
    .article { min-width: 0; }

    h1 {
      font-size: clamp(1.4rem, 3.5vw, 1.9rem);
      line-height: 1.4;
      margin: 0 0 12px;
    }

    .date {
      font-size: 0.8rem;
      color: var(--muted);
      margin-bottom: 0;
    }

    hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 24px 0;
    }

    /* ===== 本文 ===== */
    .content { font-size: 1rem; line-height: 1.9; color: var(--subtext); }
    .content p { margin-bottom: 16px; }
    .content strong { font-weight: 700; color: var(--text); }
    .content em { font-style: italic; }

    .content h2 {
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--text);
      margin-top: 40px;
      margin-bottom: 12px;
      padding-bottom: 8px;
      border-bottom: 2px solid var(--border);
    }
    .content h3 {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--text);
      margin-top: 28px;
      margin-bottom: 8px;
    }
    .content a {
      color: var(--accent-1);
      text-decoration: underline;
      text-decoration-color: rgba(91,79,255,0.3);
      text-underline-offset: 3px;
      transition: color 0.2s;
    }
    .content a:hover { color: var(--accent-2); }

    .content ul { list-style: none; padding-left: 0; margin-bottom: 16px; }
    .content ul li {
      padding-left: 1.4em;
      position: relative;
      margin-bottom: 8px;
      color: var(--subtext);
    }
    .content ul li::before {
      content: '✦';
      position: absolute;
      left: 0;
      font-size: 0.6em;
      top: 0.35em;
      background: var(--gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .content ol { padding-left: 1.5em; margin-bottom: 16px; }
    .content ol li { margin-bottom: 8px; color: var(--subtext); }

    .content table {
      width: 100%;
      border-collapse: collapse;
      margin: 20px 0;
      font-size: 0.9rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
    }
    .content th {
      background: var(--surface-2);
      color: var(--text);
      font-weight: 700;
      text-align: left;
      padding: 10px 14px;
      border-bottom: 1px solid var(--border);
    }
    .content td {
      padding: 10px 14px;
      color: var(--subtext);
      border-bottom: 1px solid var(--border);
    }
    .content tr:last-child td { border-bottom: none; }

    .content code {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 2px 6px;
      font-size: 0.85em;
      font-family: 'Courier New', monospace;
      color: var(--accent-1);
    }
    .content hr { border: none; border-top: 1px solid var(--border); margin: 32px 0; }
    .content img { max-width: 100%; border-radius: 8px; margin: 16px 0; }

    /* ===== 記事下CTA ===== */
    .cta {
      margin-top: 60px;
      padding: 24px;
      border: 1px solid var(--border);
      border-radius: 16px;
      background: var(--surface);
    }
    .cta h2 { margin: 0 0 8px; font-size: 1.1rem; }
    .cta-buttons { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 14px; }

    /* ===== サイドバー ===== */
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 20px;
      position: sticky;
      top: 80px;
    }

    .sidebar-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 18px;
      box-shadow: 0 2px 8px rgba(15,17,23,0.05);
    }

    .sidebar-card__title {
      font-size: 0.78rem;
      font-weight: 700;
      color: var(--text);
      letter-spacing: 0.05em;
      text-transform: uppercase;
      margin-bottom: 12px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
    }

    /* 目次 */
    .toc { font-size: 0.85rem; }
    .toc-loading { font-size: 0.8rem; color: var(--muted); margin: 0; }
    .toc ol { list-style: none; padding: 0; margin: 0; counter-reset: toc; }
    .toc ol li { counter-increment: toc; margin-bottom: 8px; padding-left: 0; }
    .toc ol li::before { display: none; }
    .toc a {
      display: flex;
      gap: 8px;
      align-items: baseline;
      color: var(--subtext);
      text-decoration: none;
      font-size: 0.82rem;
      line-height: 1.5;
      transition: color 0.2s;
    }
    .toc a::before {
      content: counter(toc);
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--accent-1);
      background: rgba(91,79,255,0.08);
      border-radius: 4px;
      padding: 1px 5px;
      flex-shrink: 0;
    }
    .toc a:hover { color: var(--accent-1); text-decoration: none; }
    .toc a.active { color: var(--accent-1); font-weight: 600; }

    /* おすすめ記事 */
    .rec-list { list-style: none; padding: 0; margin: 0; }
    .rec-item {
      margin-bottom: 12px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
    }
    .rec-item:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
    .rec-item::before { display: none; }
    .rec-link {
      display: block;
      font-size: 0.83rem;
      font-weight: 500;
      color: var(--text);
      text-decoration: none;
      line-height: 1.5;
      margin-bottom: 4px;
      transition: color 0.2s;
    }
    .rec-link:hover { color: var(--accent-1); text-decoration: none; }
    .rec-date { font-size: 0.75rem; color: var(--muted); }

    /* サイドバーCTA */
    .sidebar-cta {
      background: linear-gradient(135deg, rgba(91,79,255,0.06), rgba(14,165,233,0.06));
      border-color: rgba(91,79,255,0.15);
      text-align: center;
    }
    .sidebar-cta__emoji { font-size: 2rem; margin-bottom: 8px; }
    .sidebar-cta__title { font-size: 0.95rem; font-weight: 700; color: var(--text); margin-bottom: 8px; }
    .sidebar-cta__desc { font-size: 0.8rem; color: var(--subtext); margin-bottom: 14px; line-height: 1.6; }

    /* ===== モバイル ===== */
    @media (max-width: 860px) {
      .page-layout { grid-template-columns: 1fr; }
      .sidebar { position: static; }
      #toc-card { display: none; }
      .cta-buttons { flex-direction: column; }
    }
  </style>

  <script>
    // 目次を自動生成
    const content = document.querySelector('.content');
    const toc = document.getElementById('toc');
    if (content && toc) {
      const headings = content.querySelectorAll('h2');
      if (headings.length > 0) {
        const ol = document.createElement('ol');
        headings.forEach((h, i) => {
          if (!h.id) h.id = `heading-${i}`;
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = `#${h.id}`;
          a.textContent = h.textContent;
          a.addEventListener('click', (e) => {
            e.preventDefault();
            h.scrollIntoView({ behavior: 'smooth', block: 'start' });
          });
          li.appendChild(a);
          ol.appendChild(li);
        });
        toc.innerHTML = '';
        toc.appendChild(ol);

        // アクティブ見出しのハイライト
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const id = entry.target.id;
              const link = toc.querySelector(`a[href="#${id}"]`);
              if (link) {
                if (entry.isIntersecting) {
                  toc.querySelectorAll('a').forEach((a) => a.classList.remove('active'));
                  link.classList.add('active');
                }
              }
            });
          },
          { rootMargin: '-20% 0px -70% 0px' }
        );
        headings.forEach((h) => observer.observe(h));
      } else {
        document.getElementById('toc-card')?.remove();
      }
    }
  </script>

</Layout>

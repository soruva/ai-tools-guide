---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

const sortedPosts = posts.sort(
  (a, b) =>
    new Date(b.data.date).getTime() -
    new Date(a.data.date).getTime()
);
---

<Layout title="初心者向けAIツール比較ガイド">

  <!-- ヒーロー -->
  <section>

    <h1>
      AIツールで迷っている人へ
    </h1>

    <p>
      ChatGPT・Claude・Geminiの違いから、副業での使い方まで
      <strong>初心者が最短で理解できるように整理したサイトです。</strong>
    </p>

    <p>
      AIツール選びで迷わないように、必要な情報だけをまとめています。
    </p>

    <a href="/tools/chatgpt" class="cta-btn">
      まずはChatGPTを無料で試す
    </a>

  </section>

  <!-- このサイトで分かること -->
  <section>

    <h2>このサイトで分かること</h2>

    <ul>
      <li>ChatGPT・Claude・Geminiの違い</li>
      <li>初心者が最初にやるべきこと</li>
      <li>AIを副業に使う具体的な方法</li>
    </ul>

  </section>

  <!-- 比較 -->
  <section>

    <h2>人気AIツール比較</h2>

    <p>
      まずは「どれを使うか」をここで決めてください。
    </p>

    <table>
      <thead>
        <tr>
          <th>ツール</th>
          <th>特徴</th>
          <th>おすすめ用途</th>
        </tr>
      </thead>

      <tbody>
        <tr>
          <td>ChatGPT</td>
          <td>万能型</td>
          <td>初心者向け</td>
        </tr>

        <tr>
          <td>Claude</td>
          <td>文章が自然</td>
          <td>ブログ向け</td>
        </tr>

        <tr>
          <td>Gemini</td>
          <td>検索強い</td>
          <td>リサーチ</td>
        </tr>
      </tbody>
    </table>

    <!-- 意思決定直後CTA -->
    <p>
      まずはChatGPTから始めるのが一番シンプルです。
    </p>

    <a href="/tools/chatgpt" class="cta-btn">
      まずはChatGPTを試す
    </a>

    <!-- 補足 -->
    <p>
      無料で使えるので、まず触ってみるのが一番早いです。
    </p>

    <!-- 最後の後押しCTA -->
    <a href="/tools/chatgpt" class="cta-btn">
      ChatGPTで始める（無料）
    </a>

  </section>

  <!-- 記事一覧 -->
  <section>

    <h2>最新記事</h2>

    <ul>
      {sortedPosts.map((post) => (
        <li>
          <a href={`/posts/${post.slug}`}>
            {post.data.title}
          </a>

          <div style="font-size:0.8rem; color:#888;">
            {post.data.date}
          </div>
        </li>
      ))}
    </ul>

  </section>

</Layout>

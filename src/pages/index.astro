---
const pageTitle = "AI Tools Guide";
const posts = [
  { title: "ChatGPTгҒЁClaude 3.5гӮ’еҫ№еә•жҜ”ијғпјҒ", url: "/posts/compare-ai" },
  { title: "AIеҲқеҝғиҖ…гҒҢеүҜжҘӯгҒ§жңҲ5дёҮзЁјгҒҗгғӯгғјгғүгғһгғғгғ—", url: "/posts/roadmap" }
];
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{pageTitle}</title>
    <style>
      body { font-family: sans-serif; max-width: 800px; margin: 0 auto; padding: 20px; line-height: 1.6; }
      h1 { color: #333; border-bottom: 2px solid #0070f3; }
      .post-list { list-style: none; padding: 0; }
      .post-item { margin: 10px 0; padding: 10px; border: 1px solid #ddd; border-radius: 5px; }
      a { text-decoration: none; color: #0070f3; font-weight: bold; }
    </style>
  </head>
  <body>
    <h1>{pageTitle}</h1>
    <p>жңҖж–°гҒ®AIгғ„гғјгғ«гӮ„SaaSгӮ’еҺійҒёгҒ—гҖҒжҜ”ијғгғ»гғ¬гғ“гғҘгғјгӮ’йҖҡгҒҳгҒҰжңҖйҒ©гҒӘйҒёжҠһгӮ’гӮөгғқгғјгғҲгҒҷгӮӢжғ…е ұгӮөгӮӨгғҲгҒ§гҒҷгҖӮ</p>
    <h2>жңҖж–°иЁҳдәӢ</h2>
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-item"><a href={post.url}>{post.title}</a></li>
      ))}
    </ul>
  </body>
</html>

---
import Layout from '../layouts/Layout.astro';
const posts = await Astro.glob('../content/blog/*.md');
---
<Layout title="最新のAIツール比較・活用ガイド">
  <h1>AI Tools Guide</h1>
  <p>最新AI（ChatGPT, Claude等）の比較と、初心者向け活用法を発信します。</p>
  <h2>最新記事</h2>
  <ul>
    {posts.map((post) => (
      <li>
        <a href={post.url}>{post.frontmatter.title}</a> — {post.frontmatter.date}
      </li>
    ))}
  </ul>
</Layout>

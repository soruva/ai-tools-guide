---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const posts = await getCollection('blog');
const sortedPosts = posts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---
<Layout title="初心者向けAIツール比較ガイド">

  <!-- ヒーロー -->
  <section class="hero">
    <div class="hero__bg">
      <div class="hero__orb hero__orb--1"></div>
      <div class="hero__orb hero__orb--2"></div>
      <div class="hero__grid"></div>
    </div>
    <div class="hero__content">
      <div class="hero__badge">AI Tools Guide 2026</div>
      <h1 class="hero__title">
        AIツールで、<br>働き方を変えたい人へ
      </h1>
      <p class="hero__desc">
        「どれを使えばいいの？」から「どう稼ぐの？」「どうキャリアアップするの？」まで。<br>
        <strong>AIツールの比較・活用・副業・転職まで、初心者にわかりやすく整理しています。</strong>
      </p>
      <div class="hero__actions">
        <a href="/tools/chatgpt" class="cta-btn">まずはChatGPTを無料で試す</a>
        <a href="#tools" class="hero__scroll-link">比較を見る ↓</a>
      </div>
    </div>
    <div class="hero__cards">
      <div class="hero__tool-card hero__tool-card--1">
        <span class="tool-card__name">ChatGPT</span>
        <span class="tool-card__tag">万能型</span>
      </div>
      <div class="hero__tool-card hero__tool-card--2">
        <span class="tool-card__name">Claude</span>
        <span class="tool-card__tag">文章特化</span>
      </div>
      <div class="hero__tool-card hero__tool-card--3">
        <span class="tool-card__name">Gemini</span>
        <span class="tool-card__tag">検索強化</span>
      </div>
    </div>
  </section>

  <!-- このサイトで分かること -->
  <section class="features">
    <h2 class="section-title">このサイトで分かること</h2>
    <div class="features__grid">
      <div class="feature-card">
        <div class="feature-card__num">01</div>
        <div class="feature-card__body">
          <div class="feature-card__title">AIツールの違い</div>
          <p class="feature-card__desc">ChatGPT・Claude・Geminiをわかりやすく比較。どれを選ぶべきか迷わなくなります。</p>
        </div>
      </div>
      <div class="feature-card">
        <div class="feature-card__num">02</div>
        <div class="feature-card__body">
          <div class="feature-card__title">初心者のはじめ方</div>
          <p class="feature-card__desc">難しい知識は不要。今日から使えるシンプルな3ステップで始められます。</p>
        </div>
      </div>
      <div class="feature-card">
        <div class="feature-card__num">03</div>
        <div class="feature-card__body">
          <div class="feature-card__title">AIを副業に活かす</div>
          <p class="feature-card__desc">ブログ・ライティング・SNS運用。AIで作業時間を半分にする具体的な方法。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 比較テーブル -->
  <section class="compare" id="tools">
    <h2 class="section-title">人気AIツール比較</h2>
    <p class="section-sub">まずは「どれを使うか」をここで決めてください。</p>
    <div class="compare__table-wrap">
      <table class="compare__table">
        <thead>
          <tr>
            <th>ツール</th>
            <th>特徴</th>
            <th>おすすめ用途</th>
            <th>無料版</th>
          </tr>
        </thead>
        <tbody>
          <tr class="compare__row--highlight">
            <td><strong>ChatGPT</strong></td>
            <td>万能型・使いやすい</td>
            <td>初心者・なんでも</td>
            <td>あり</td>
          </tr>
          <tr>
            <td><strong>Claude</strong></td>
            <td>文章が自然で読みやすい</td>
            <td>ブログ・ライティング</td>
            <td>あり</td>
          </tr>
          <tr>
            <td><strong>Gemini</strong></td>
            <td>Google検索との連携</td>
            <td>リサーチ・調査</td>
            <td>あり</td>
          </tr>
        </tbody>
      </table>
    </div>
    <div class="compare__cta">
      <p>まずはChatGPTから始めるのが一番シンプルです。</p>
      <a href="/tools/chatgpt" class="cta-btn">ChatGPTで始める（無料）</a>
    </div>
  </section>

  <!-- 最新記事 -->
  <section class="posts">
    <h2 class="section-title">最新記事</h2>
    <div class="posts__grid">
      {sortedPosts.map((post, i) => (
        <a href={`/posts/${post.slug}`} class={`post-card ${i === 0 ? 'post-card--featured' : ''}`}>
          <div class="post-card__meta">
            <span class="post-card__date">{post.data.date}</span>
            {i === 0 && <span class="post-card__badge">最新</span>}
          </div>
          <div class="post-card__title">{post.data.title}</div>
          <div class="post-card__arrow">→</div>
        </a>
      ))}
    </div>
  </section>

  <style>
    /* ===== セクション共通 ===== */
    .section-title {
      font-size: clamp(1.2rem, 3vw, 1.5rem);
      font-weight: 700;
      color: var(--text);
      margin: 0 0 8px;
      letter-spacing: -0.02em;
    }
    .section-sub {
      color: var(--subtext);
      font-size: 0.95rem;
      margin: 0 0 24px;
    }

    /* ===== ヒーロー ===== */
    .hero {
      position: relative;
      border-radius: 24px;
      overflow: hidden;
      padding: 60px 48px;
      margin-bottom: 20px;
      background: linear-gradient(135deg, #0f1117 0%, #1a1f35 100%);
      min-height: 380px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 40px;
      align-items: center;
      box-shadow: 0 20px 60px rgba(91,79,255,0.15);
    }

    .hero__bg {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .hero__orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(60px);
    }
    .hero__orb--1 {
      width: 400px; height: 400px;
      top: -150px; right: 100px;
      background: radial-gradient(circle, rgba(91,79,255,0.35), transparent 70%);
      animation: orbFloat 12s ease-in-out infinite alternate;
    }
    .hero__orb--2 {
      width: 300px; height: 300px;
      bottom: -100px; left: 50px;
      background: radial-gradient(circle, rgba(14,165,233,0.25), transparent 70%);
      animation: orbFloat 16s ease-in-out infinite alternate-reverse;
    }

    .hero__grid {
      display: none;
    }

    @keyframes orbFloat {
      0%   { transform: translate(0, 0); }
      100% { transform: translate(20px, -20px); }
    }

    .hero__content {
      position: relative;
      z-index: 1;
    }

    .hero__badge {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.6);
      border: 1px solid rgba(255,255,255,0.15);
      padding: 4px 12px;
      border-radius: 999px;
      margin-bottom: 20px;
      background: rgba(255,255,255,0.05);
    }

    .hero__title {
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 700;
      color: #ffffff;
      letter-spacing: -0.04em;
      line-height: 1.2;
      margin: 0 0 20px;
    }

    .hero__desc {
      color: rgba(255,255,255,0.65);
      font-size: 0.95rem;
      line-height: 1.8;
      margin: 0 0 28px;
      max-width: 480px;
    }

    .hero__desc strong {
      color: rgba(255,255,255,0.9);
      font-weight: 600;
    }

    .hero__actions {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }

    .hero__scroll-link {
      font-size: 0.85rem;
      color: rgba(255,255,255,0.5);
      text-decoration: none;
      transition: color 0.2s;
    }
    .hero__scroll-link:hover {
      color: rgba(255,255,255,0.9);
      text-decoration: none;
    }

    /* ヒーロー右側のツールカード */
    .hero__cards {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .hero__tool-card {
      background: rgba(255,255,255,0.18);
      border: 1px solid rgba(255,255,255,0.4);
      border-radius: 12px;
      padding: 14px 20px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      backdrop-filter: blur(8px);
      transition: background 0.2s, transform 0.2s;
      min-width: 180px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.2);
    }
    .hero__tool-card:hover {
      background: rgba(255,255,255,0.26);
      transform: translateX(-4px);
    }
    .hero__tool-card--1 { animation: cardIn 0.6s 0.1s both; }
    .hero__tool-card--2 { animation: cardIn 0.6s 0.2s both; }
    .hero__tool-card--3 { animation: cardIn 0.6s 0.3s both; }

    @keyframes cardIn {
      from { opacity: 0; transform: translateX(20px); }
      to   { opacity: 1; transform: translateX(0); }
    }

    .tool-card__name {
      font-size: 0.9rem;
      font-weight: 700;
      color: #ffffff;
    }
    .tool-card__tag {
      font-size: 0.72rem;
      font-weight: 600;
      color: rgba(255,255,255,0.5);
      background: rgba(255,255,255,0.08);
      padding: 3px 10px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.1);
    }

    /* ===== フィーチャーカード ===== */
    .features {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 36px 32px;
      margin-bottom: 20px;
      box-shadow: var(--shadow-sm);
    }

    .features__grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
      margin-top: 24px;
    }

    .feature-card {
      display: flex;
      gap: 16px;
      align-items: flex-start;
      padding: 20px;
      background: var(--surface-2);
      border-radius: 12px;
      border: 1px solid var(--border);
      transition: box-shadow 0.2s, transform 0.2s;
    }
    .feature-card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
    }

    .feature-card__num {
      font-family: 'DM Sans', sans-serif;
      font-size: 1.6rem;
      font-weight: 700;
      line-height: 1;
      background: var(--gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      flex-shrink: 0;
    }

    .feature-card__title {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 6px;
    }

    .feature-card__desc {
      font-size: 0.82rem;
      color: var(--subtext);
      line-height: 1.7;
      margin: 0;
    }

    /* ===== 比較テーブル ===== */
    .compare {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 36px 32px;
      margin-bottom: 20px;
      box-shadow: var(--shadow-sm);
    }

    .compare__table-wrap {
      overflow-x: auto;
      border-radius: 12px;
      border: 1px solid var(--border);
      margin: 20px 0;
    }

    .compare__table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
      margin: 0;
      border: none;
      border-radius: 0;
    }

    .compare__table th {
      background: var(--surface-2);
      padding: 12px 20px;
      font-size: 0.75rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .compare__table td {
      padding: 14px 20px;
    }

    .compare__row--highlight td {
      background: rgba(91,79,255,0.04);
    }
    .compare__row--highlight td:first-child {
      border-left: 3px solid var(--accent-1);
    }

    .compare__cta {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-top: 8px;
      flex-wrap: wrap;
    }
    .compare__cta p {
      margin: 0;
      font-size: 0.9rem;
    }

    /* ===== 記事一覧 ===== */
    .posts {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 36px 32px;
      box-shadow: var(--shadow-sm);
    }

    .posts__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      margin-top: 24px;
    }

    .post-card {
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: 20px;
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-radius: 12px;
      text-decoration: none;
      transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
      position: relative;
      overflow: hidden;
    }
    .post-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 3px; height: 100%;
      background: var(--gradient);
      opacity: 0;
      transition: opacity 0.2s;
    }
    .post-card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-2px);
      border-color: rgba(91,79,255,0.2);
      text-decoration: none;
    }
    .post-card:hover::before { opacity: 1; }

    .post-card--featured {
      grid-column: 1 / -1;
      background: linear-gradient(135deg, rgba(91,79,255,0.04), rgba(14,165,233,0.04));
      border-color: rgba(91,79,255,0.15);
    }

    .post-card__meta {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .post-card__date {
      font-size: 0.75rem;
      color: var(--muted);
    }

    .post-card__badge {
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #fff;
      background: var(--gradient);
      padding: 2px 8px;
      border-radius: 999px;
    }

    .post-card__title {
      font-size: 0.92rem;
      font-weight: 600;
      color: var(--text);
      line-height: 1.5;
      flex: 1;
    }

    .post-card__arrow {
      font-size: 0.8rem;
      color: var(--accent-1);
      opacity: 0;
      transition: opacity 0.2s, transform 0.2s;
      transform: translateX(-4px);
    }
    .post-card:hover .post-card__arrow {
      opacity: 1;
      transform: translateX(0);
    }

    /* ===== レスポンシブ ===== */
    @media (max-width: 860px) {
      .hero {
        grid-template-columns: 1fr;
        padding: 40px 28px;
      }
      .hero__cards { flex-direction: row; flex-wrap: wrap; }
      .hero__tool-card { min-width: 140px; flex: 1; }
      .features__grid { grid-template-columns: 1fr; }
      .posts__grid { grid-template-columns: 1fr; }
      .post-card--featured { grid-column: auto; }
    }

    @media (max-width: 600px) {
      .hero { padding: 32px 20px; }
      .features, .compare, .posts { padding: 24px 18px; }
      .compare__cta { flex-direction: column; align-items: flex-start; }
    }
  </style>

</Layout>

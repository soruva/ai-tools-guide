---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

const sortedPosts = posts.sort(
  (a, b) =>
    new Date(b.data.date).getTime() -
    new Date(a.data.date).getTime()
);
---

<Layout title="初心者向けAIツール比較ガイド">

  <section>
    <h1>AIツール、どれを使えばいいのか迷っていませんか</h1>
    <p>
      ChatGPT・Claude・Geminiの違いを、初心者向けにシンプルに整理しています。
    </p>

    <a href="/start" class="cta-btn">5分でわかるAIの始め方</a>
  </section>

  <section>
    <h2>人気AIツール比較</h2>

    <table>
      <thead>
        <tr>
          <th>ツール</th>
          <th>特徴</th>
          <th>おすすめ用途</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>ChatGPT</td>
          <td>万能型</td>
          <td>初心者向け</td>
        </tr>
        <tr>
          <td>Claude</td>
          <td>文章が自然</td>
          <td>ブログ向け</td>
        </tr>
        <tr>
          <td>Gemini</td>
          <td>検索強い</td>
          <td>リサーチ</td>
        </tr>
      </tbody>
    </table>

    <a href="/tools/chatgpt" class="cta-btn">ChatGPTを試す</a>
  </section>

  <section>
    <h2>最新記事</h2>

    <ul>
      {sortedPosts.map((post) => (
        <li>
          <a href={`/posts/${post.slug}`}>
            {post.data.title}
          </a>

          <div style="font-size:0.8rem; color:#888;">
            {post.data.date}
          </div>
        </li>
      ))}
    </ul>
  </section>

</Layout>

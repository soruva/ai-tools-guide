---
import Layout from '../layouts/Layout.astro';
const posts = await Astro.glob('../content/blog/*.md');
---

<Layout title="初心者向けAIツール比較ガイド">

  <!-- ヒーロー -->
  <section>
    <h1>AIツール、どれを使う？</h1>
    <p>
      ChatGPT・Claude・Geminiの違いを、初心者向けにシンプルに解説。
    </p>
    <p>迷ったら、まずこれだけ見ればOKです。</p>

    <a href="/start" class="cta-btn">▶ 5分でわかるAIの始め方</a>
  </section>

  <!-- 比較（最重要） -->
  <section>
    <h2>人気AIツール比較</h2>

    <table>
      <thead>
        <tr>
          <th>ツール</th>
          <th>特徴</th>
          <th>おすすめ用途</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>ChatGPT</strong></td>
          <td>万能・初心者でもすぐ使える</td>
          <td>最初の1つに最適</td>
          <td><a href="/tools/chatgpt" class="cta-btn">使ってみる</a></td>
        </tr>
        <tr>
          <td><strong>Claude</strong></td>
          <td>文章作成が自然で高品質</td>
          <td>ブログ・ライティング</td>
          <td><a href="/tools/claude" class="cta-btn">詳細</a></td>
        </tr>
        <tr>
          <td><strong>Gemini</strong></td>
          <td>Google連携・検索に強い</td>
          <td>情報収集・調査</td>
          <td><a href="/tools/gemini" class="cta-btn">詳細</a></td>
        </tr>
      </tbody>
    </table>

    <!-- 🔥 追記①：判断を明確化 -->
    <p>
      👉 迷っているなら、まずは<strong>ChatGPT</strong>から始めるのがおすすめです。
    </p>

    <!-- 🔥 追記②：即CTA -->
    <a href="/tools/chatgpt" class="cta-btn">
      ▶ 今すぐChatGPTを試す
    </a>
  </section>

  <!-- 🔥 追記③：ベネフィット -->
  <section>
    <h2>AIを使うと何が変わる？</h2>
    <ul>
      <li>作業時間が大幅に短縮できる</li>
      <li>文章作成やアイデア出しが一瞬でできる</li>
      <li>副業や収入アップのチャンスが広がる</li>
    </ul>
  </section>

  <!-- CTA強化 -->
  <section>
    <h2>まずは1つ使ってみる</h2>
    <p>
      AIは「読むより触る」が一番早いです。
    </p>

    <a href="/tools/chatgpt" class="cta-btn">▶ ChatGPTを無料で使う</a>
  </section>

  <!-- ナビ -->
  <section>
    <h2>目的から探す</h2>
    <ul>
      <li><a href="/category/fukugyo">副業で使う</a></li>
      <li><a href="/category/blog">ブログ運営</a></li>
      <li><a href="/category/work">業務効率化</a></li>
    </ul>
  </section>

  <!-- 🔥 追記④：信頼強化 -->
  <section>
    <h2>このサイトについて</h2>
    <p>
      AI Tools Guideでは、初心者でも安心して使えるAIツールを厳選し、
      実際の使い方とあわせて分かりやすく紹介しています。
    </p>
  </section>

  <!-- 記事一覧 -->
  <section>
    <h2>最新記事</h2>
    <ul>
      {posts.map((post) => (
        <li>
          <a href={`/posts/${post.file.split('/').pop().split('.').shift()}`}>
            {post.frontmatter.title}
          </a>
          <div style="font-size:0.8rem; color:#888;">
            {post.frontmatter.date}
          </div>
        </li>
      ))}
    </ul>
  </section>

</Layout>

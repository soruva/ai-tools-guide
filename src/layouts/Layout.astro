---
const { title } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | AIツール比較ガイド</title>

    <style is:global>
      :root {
        --bg: #fafafa;
        --text: #111111;
        --subtext: #666666;
        --border: #eaeaea;
        --card: #ffffff;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Inter", Arial, sans-serif;
        max-width: 720px;
        margin: 0 auto;
        padding: 24px 18px 60px;
        line-height: 1.8;
        color: var(--text);
        background: var(--bg);
      }

      nav {
        display: flex;
        justify-content: space-between;
        margin-bottom: 40px;
      }

      nav a {
        text-decoration: none;
        color: var(--subtext);
      }

      h1 {
        font-size: 2.2rem;
        margin-bottom: 20px;
      }

      h2 {
        font-size: 1.2rem;
        margin-top: 40px;
      }

      p {
        color: var(--subtext);
      }

      table {
        width: 100%;
        border-collapse: collapse;
        margin: 30px 0;
        background: var(--card);
        border: 1px solid var(--border);
      }

      th, td {
        padding: 12px;
        border: 1px solid var(--border);
        text-align: left;
      }

      th {
        background: #f3f3f3;
      }

      @media (max-width: 600px) {
        table {
          display: block;
          overflow-x: auto;
        }
      }

      footer {
        margin-top: 60px;
        font-size: 0.75rem;
        color: #aaa;
        text-align: center;
      }
    </style>
  </head>

  <body>
  <nav>
  <a href="/">AIツール比較ガイド</a>

  <div>
    <a href="/start">はじめる</a>
    <a href="/about">運営者情報</a>
    <a href="/privacy">プライバシーポリシー</a>
  </div>
</nav>

    <main>
      <slot />
    </main>

    <footer>© 2026 AIツール比較ガイド</footer>
  </body>
</html>

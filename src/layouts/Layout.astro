---
const { title } = Astro.props;
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{title} | AI Tools Guide</title>
    <style is:global>
  /* 1. 海外サイトで人気のフォントスタック */
  :root {
    --primary: #0984e3;
    --text: #1d1d1f; /* Appleがよく使う深い黒 */
    --bg: #ffffff;
    --card-bg: #f5f5f7;
  }

  body { 
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    max-width: 900px; 
    margin: 0 auto; 
    padding: 60px 20px; 
    line-height: 1.6; 
    color: var(--text);
    background-color: var(--bg);
    -webkit-font-smoothing: antialiased; /* 文字をクッキリさせる海外の定番設定 */
  }

  /* 2. ナビゲーションの「浮遊感」とアニメーション */
  nav { 
    position: sticky;
    top: 20px;
    z-index: 100;
    margin-bottom: 80px; 
    padding: 12px 30px; 
    background: rgba(255, 255, 255, 0.8); 
    backdrop-filter: blur(20px); /* 海外サイトで流行中の「すりガラス」効果 */
    border-radius: 50px; 
    border: 1px solid rgba(0,0,0,0.05);
    display: flex;
    justify-content: center;
    gap: 30px;
  }

  nav a { 
    text-decoration: none; 
    color: var(--text); 
    font-weight: 500; 
    font-size: 0.95rem;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); /* 加速感のある動き */
  }

  nav a:hover { color: var(--primary); transform: translateY(-1px); }

  /* 3. 記事カード：LinearやAppleのようなミニマリズム */
  li { 
    background: var(--card-bg); 
    margin-bottom: 24px; 
    padding: 32px; 
    border-radius: 20px; 
    list-style: none; 
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1); /* 高級感のあるゆっくりした動き */
    border: 1px solid transparent;
  }

  li:hover { 
    background: #fff;
    transform: scale(1.02); /* ほんの少し大きく */
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    border-color: rgba(9, 132, 227, 0.2);
  }

  h1 { font-size: 2.5rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 40px; }
  h2 { font-size: 1.8rem; margin-top: 40px; }

  /* 4. スルスル動くスクロール */
  html { scroll-behavior: smooth; }
</style>

  </head>
  <body>
    <nav>
      <a href="/">HOME</a>
      <a href="/about">運営者情報</a>
      <a href="/about#contact">お問い合わせ</a>
    </nav>
    <slot />
    <footer>© 2026 AI Tools Guide</footer>
  </body>
</html>

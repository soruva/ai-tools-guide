---
const { title } = Astro.props;
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{title} | AIツール比較ガイド</title>
    <link rel="stylesheet" href="/src/styles/global.css">
    <style is:global>
      :root {
        --bg: #fafafa;
        --text: #111111;
        --subtext: #666666;
        --border: #eaeaea;
        --card: #ffffff;
        --accent: #111111;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Inter", "Helvetica Neue", Arial, sans-serif;
        max-width: 720px;
        margin: 0 auto;
        padding: 24px 18px 60px;
        line-height: 1.8;
        color: var(--text);
        background: var(--bg);
      }

      /* ナビ */
      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 50px;
        font-size: 0.9rem;
      }

      nav .left a {
        font-weight: 600;
        text-decoration: none;
        color: var(--text);
      }

      nav .right {
        display: flex;
        gap: 20px;
      }

      nav a {
        text-decoration: none;
        color: var(--subtext);
      }

      nav a:hover {
        color: var(--text);
      }

      /* タイトル */
      h1 {
        font-size: 2.2rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 20px;
      }

      h2 {
        font-size: 1.2rem;
        margin-top: 40px;
        margin-bottom: 10px;
        font-weight: 600;
      }

      p {
        color: var(--subtext);
      }

      ul {
        padding: 0;
      }

      li {
        list-style: none;
        padding: 18px 0;
        border-bottom: 1px solid var(--border);
      }

      /* CTA */
      .cta-btn {
        display: inline-block;
        margin-top: 12px;
        padding: 10px 16px;
        border: 1px solid var(--text);
        border-radius: 999px;
        text-decoration: none;
        font-size: 0.9rem;
        color: var(--text);
      }

      .cta-btn:hover {
        background: var(--text);
        color: #fff;
      }

      section {
        margin-bottom: 40px;
      }

      footer {
        margin-top: 60px;
        font-size: 0.75rem;
        color: #aaa;
        text-align: center;
      }

      @media (max-width: 600px) {
        h1 {
          font-size: 1.8rem;
        }

        nav {
          flex-direction: column;
          align-items: flex-start;
          gap: 10px;
        }
      }
    </style>
  </head>

  <body>
    <nav>
      <div class="left">
        <a href="/">AIツール比較ガイド</a>
      </div>
      <div class="right">
        <a href="/start">はじめる</a>
        <a href="/about">このサイトについて</a>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer>
      © 2026 AIツール比較ガイド
    </footer>
  </body>
</html>

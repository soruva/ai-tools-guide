---
const { title } = Astro.props;
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{title} | AIツール比較ガイド</title>
    <link rel="stylesheet" href="/src/styles/global.css">
        <style is:global>
      :root {
        --bg: #fafafa;
        --text: #111111;
        --subtext: #666666;
        --border: #eaeaea;
        --card: #ffffff;
        --accent: #111111;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Inter", "Helvetica Neue", Arial, sans-serif;
        max-width: 720px;
        margin: 0 auto;
        padding: 24px 18px 60px;
        line-height: 1.8;
        color: var(--text);
        background: var(--bg);
      }

      /* ナビ */
      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 50px;
        font-size: 0.9rem;
      }

      nav .left a {
        font-weight: 600;
        text-decoration: none;
        color: var(--text);
      }

      nav .right {
        display: flex;
        gap: 20px;
      }

      nav a {
        text-decoration: none;
        color: var(--subtext);
      }

      nav a:hover {
        color: var(--text);
      }

      /* タイトル */
      h1 {
        font-size: 2.2rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 20px;
      }

      h2 {
        font-size: 1.2rem;
        margin-top: 40px;
        margin-bottom: 10px;
        font-weight: 600;
      }

      p {
        color: var(--subtext);
      }

      /* リスト (通常のリストのみに適用、テーブル内には干渉させない) */
      main > ul, main section > ul {
        padding: 0;
      }

      main > ul li, main section > ul li {
        list-style: none;
        padding: 18px 0;
        border-bottom: 1px solid var(--border);
      }

      /* ===== テーブル (Markdown対応) ===== */
      table {
        width: 100%;
        border-collapse: collapse;
        margin: 30px 0;
        font-size: 0.95rem;
        background: var(--card);
        border: 1px solid var(--border);
      }

      th {
        background: #f1f1f1;
        color: var(--text);
        font-weight: 600;
        text-align: left;
        padding: 12px 15px;
        border: 1px solid var(--border);
      }

      td {
        padding: 12px 15px;
        border: 1px solid var(--border);
        color: var(--subtext);
      }

      /* モバイルで横スクロール可能にする */
      @media (max-width: 600px) {
        table {
          display: block;
          overflow-x: auto;
          white-space: nowrap;
        }
      }

      /* CTA */
      .cta-btn {
        display: inline-block;
        margin-top: 12px;
        padding: 10px 16px;
        border: 1px solid var(--text);
        border-radius: 999px;
        text-decoration: none;
        font-size: 0.9rem;
        color: var(--text);
      }

      .cta-btn:hover {
        background: var(--text);
        color: #fff;
      }

      section {
        margin-bottom: 40px;
      }

      footer {
        margin-top: 60px;
        font-size: 0.75rem;
        color: #aaa;
        text-align: center;
      }

      @media (max-width: 600px) {
        h1 {
          font-size: 1.8rem;
        }

        nav {
          flex-direction: column;
          align-items: flex-start;
          gap: 10px;
        }
      }
    </style>

</html>

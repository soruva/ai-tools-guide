---
const { title } = Astro.props;
---
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{title} | AI Tools Guide</title>
    <style>
      /* Layout.astroの<style>をこれに差し替え */
body { 
  font-family: 'Helvetica Neue', Arial, sans-serif; 
  max-width: 850px; 
  margin: 0 auto; 
  padding: 40px 20px; 
  line-height: 1.8; 
  color: #2d3436; 
  background-color: #f9f9fb; /* ほんのりグレーで高級感を出す */
}
nav { 
  margin-bottom: 50px; 
  padding: 15px 25px; 
  background: #fff; 
  border-radius: 12px; 
  box-shadow: 0 4px 6px rgba(0,0,0,0.05); 
}
nav a { 
  margin-right: 20px; 
  text-decoration: none; 
  color: #0984e3; 
  font-weight: 600; 
}
h1, h2 { color: #000; border-left: 5px solid #0984e3; padding-left: 15px; }
li { 
  background: #fff; 
  margin-bottom: 20px; 
  padding: 25px; 
  border-radius: 15px; 
  list-style: none; 
  box-shadow: 0 4px 6px rgba(0,0,0,0.02); 
  transition: all 0.3s ease; /* ここで「ふわっ」とした動きの速さを指定 */
  border: 1px solid #eee;
}

li:hover { 
  transform: translateY(-5px); /* 上に5px浮き上がる */
  box-shadow: 0 12px 20px rgba(9, 132, 227, 0.15); /* 影を少し強めて浮遊感を出す */
  border-color: #0984e3; /* 枠線をレイさんのテーマカラーの青に */
}
    </style>
  </head>
  <body>
    <nav>
      <a href="/">HOME</a>
      <a href="/about">運営者情報</a>
      <a href="/about#contact">お問い合わせ</a>
    </nav>
    <slot />
    <footer>© 2026 AI Tools Guide</footer>
  </body>
</html>
